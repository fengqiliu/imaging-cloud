<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dsite.medical.cloudfilm.mapper.CfImageMapper">

    <resultMap id="CfImageResult" type="com.dsite.medical.cloudfilm.domain.entity.CfImage">
        <id property="imageId" column="image_id"/>
        <result property="examId" column="exam_id"/>
        <result property="dicomUid" column="dicom_uid"/>
        <result property="imagePath" column="image_path"/>
        <result property="thumbnailPath" column="thumbnail_path"/>
        <result property="seriesNumber" column="series_number"/>
        <result property="imageNumber" column="image_number"/>
        <result property="modality" column="modality"/>
        <result property="isKeyImage" column="is_key_image"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectImageListByExamId" resultMap="CfImageResult">
        SELECT * FROM cf_image
        WHERE exam_id = #{examId}
        ORDER BY series_number, image_number
    </select>

    <select id="countByExamId" resultType="int">
        SELECT COUNT(*) FROM cf_image WHERE exam_id = #{examId}
    </select>

</mapper>
