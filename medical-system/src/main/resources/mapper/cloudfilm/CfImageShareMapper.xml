<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dsite.medical.cloudfilm.mapper.CfImageShareMapper">

    <resultMap id="CfImageShareResult" type="com.dsite.medical.cloudfilm.domain.entity.CfImageShare">
        <id property="shareId" column="share_id"/>
        <result property="shareNo" column="share_no"/>
        <result property="examId" column="exam_id"/>
        <result property="accessCode" column="access_code"/>
        <result property="expireDate" column="expire_date"/>
        <result property="viewCount" column="view_count"/>
        <result property="downloadCount" column="download_count"/>
        <result property="allowDownload" column="allow_download"/>
        <result property="createTime" column="create_time"/>
        <result property="createUser" column="create_user"/>
    </resultMap>

    <select id="selectByShareNo" resultMap="CfImageShareResult">
        SELECT * FROM cf_image_share WHERE share_no = #{shareNo}
    </select>

    <update id="incrementViewCount">
        UPDATE cf_image_share SET view_count = view_count + 1 WHERE share_id = #{shareId}
    </update>

    <update id="incrementDownloadCount">
        UPDATE cf_image_share SET download_count = download_count + 1 WHERE share_id = #{shareId}
    </update>

</mapper>
