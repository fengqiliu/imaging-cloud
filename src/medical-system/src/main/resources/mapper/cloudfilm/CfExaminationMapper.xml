<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dsite.medical.cloudfilm.mapper.CfExaminationMapper">

    <resultMap id="CfExaminationResult" type="com.dsite.medical.cloudfilm.domain.entity.CfExamination">
        <id property="examId" column="exam_id"/>
        <result property="patientId" column="patient_id"/>
        <result property="examType" column="exam_type"/>
        <result property="examReason" column="exam_reason"/>
        <result property="examStatus" column="exam_status"/>
        <result property="applyDoctor" column="apply_doctor"/>
        <result property="examDate" column="exam_date"/>
        <result property="reportDate" column="report_date"/>
        <result property="deptId" column="dept_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <select id="selectExamListByPatientId" resultMap="CfExaminationResult">
        SELECT * FROM cf_examination
        WHERE patient_id = #{patientId} AND del_flag = '0'
        ORDER BY exam_date DESC
    </select>

</mapper>
